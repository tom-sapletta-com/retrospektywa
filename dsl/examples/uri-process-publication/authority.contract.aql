VERSION: 1

AUTHORITY retrospektywa_release:
  ALLOW read "repo://host/release/*"
  ALLOW execute "book://host/release/command/build"
  ALLOW execute "audio://host/narration/command/generate"
  ALLOW execute "test://host/release/query/verify"
  ALLOW request "human://publisher/decision/approve"

  DENY publish "github://host/release/*" WITHOUT approval
  DENY publish "sites://host/version/*" WITHOUT approval
  DENY reveal "secret://*"
  DENY bypass "test://host/release/query/verify"
