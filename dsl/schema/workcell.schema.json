{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retrospektywa.pl/schema/workcell.schema.json",
  "title": "Cybernetic WorkCell contract",
  "type": "object",
  "required": [
    "schema",
    "id",
    "version",
    "horizon",
    "goal",
    "state",
    "actor",
    "authority",
    "environment",
    "protocol",
    "validator",
    "measurements",
    "budgets",
    "acceptance",
    "escalation"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "retrospektywa.workcell/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "horizon": {
      "type": "object",
      "required": ["minutes"],
      "additionalProperties": false,
      "properties": {
        "minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "goal": {
      "type": "object",
      "required": ["state", "planned_value"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "minLength": 3
        },
        "planned_value": {
          "type": "number",
          "minimum": 0
        },
        "value_unit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "state": {
      "type": "object",
      "required": ["initial", "current"],
      "additionalProperties": false,
      "properties": {
        "initial": {
          "type": "string",
          "minLength": 1
        },
        "current": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actor": {
      "type": "object",
      "required": ["executor", "validator", "required"],
      "additionalProperties": false,
      "properties": {
        "executor": {
          "enum": ["human", "agent", "team", "hybrid"]
        },
        "validator": {
          "enum": ["human", "agent", "test", "policy", "hybrid"]
        },
        "required": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "required": ["allow", "require_approval", "deny"],
      "additionalProperties": false,
      "properties": {
        "allow": {
          "$ref": "#/$defs/actionList"
        },
        "require_approval": {
          "$ref": "#/$defs/actionList"
        },
        "deny": {
          "$ref": "#/$defs/actionList"
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["tools", "repositories", "data_classification"],
      "additionalProperties": false,
      "properties": {
        "tools": {
          "$ref": "#/$defs/stringList"
        },
        "repositories": {
          "$ref": "#/$defs/stringList"
        },
        "data_classification": {
          "enum": ["public", "internal", "confidential", "restricted"]
        }
      }
    },
    "protocol": {
      "type": "object",
      "required": ["mode", "checkpoints"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "result",
            "procedural",
            "ping_pong",
            "exception_supervision",
            "double_control",
            "exploratory",
            "incident"
          ]
        },
        "checkpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["when", "requires"],
            "additionalProperties": false,
            "properties": {
              "when": {
                "type": "string",
                "minLength": 2
              },
              "requires": {
                "$ref": "#/$defs/stringList"
              }
            }
          }
        }
      }
    },
    "validator": {
      "type": "object",
      "required": ["types", "evidence_required"],
      "additionalProperties": false,
      "properties": {
        "types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["human", "test", "policy", "agent"]
          }
        },
        "evidence_required": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "budgets": {
      "type": "object",
      "required": ["time_minutes", "validation_minutes", "cost", "expected_loss"],
      "additionalProperties": false,
      "properties": {
        "time_minutes": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "validation_minutes": {
          "type": "number",
          "minimum": 0
        },
        "cost": {
          "type": "number",
          "minimum": 0
        },
        "expected_loss": {
          "type": "number",
          "minimum": 0
        },
        "cognitive_load_max": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["tests", "evidence_complete"],
      "additionalProperties": false,
      "properties": {
        "tests": {
          "$ref": "#/$defs/stringList"
        },
        "evidence_complete": {
          "const": true
        }
      }
    },
    "escalation": {
      "type": "object",
      "required": ["conditions"],
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actionList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  }
}
