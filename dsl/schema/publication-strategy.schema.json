{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retrospektywa.pl/schema/publication-strategy.schema.json",
  "title": "Retrospektywa publication strategy",
  "type": "object",
  "required": ["strategy"],
  "additionalProperties": false,
  "properties": {
    "strategy": {
      "type": "object",
      "required": ["id", "input", "capabilities", "rules"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "input": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
        }
      }
    }
  }
}
