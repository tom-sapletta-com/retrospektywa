{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retrospektywa.pl/schema/editorial-contract.schema.json",
  "title": "Retrospektywa editorial contract",
  "type": "object",
  "required": ["editorial_contract"],
  "additionalProperties": false,
  "properties": {
    "editorial_contract": {
      "type": "object",
      "required": [
        "id",
        "version",
        "scope",
        "paragraph_roles",
        "evidence_modes",
        "prohibited_phrases",
        "concepts"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "version": {"type": "integer", "minimum": 1},
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^book/.+\\.qmd$"}
        },
        "paragraph_roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["thesis", "definition", "evidence", "mechanism", "procedure", "example", "limitation", "navigation"]}
        },
        "evidence_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["citation", "local_artifact", "derivation", "bounded_hypothesis", "operational_test", "scope_boundary"]}
        },
        "prohibited_phrases": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 2}
        },
        "concepts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "terms", "definition", "status", "validated_by"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
              "terms": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 2}
              },
              "definition": {"type": "string", "minLength": 20},
              "status": {"enum": ["standard", "project-model", "educational-projection", "operational-pattern"]},
              "validated_by": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 3}
              }
            }
          }
        }
      }
    }
  }
}
